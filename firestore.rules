rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isDemoStaffByUid() {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/staffMembers/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/staffMembers/$(request.auth.uid)).data.status == 'active';
    }

    function isDemoStaffByPhone() {
      return signedIn()
        && request.auth.token.phone_number != null
        && exists(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/staffMembers/$(request.auth.token.phone_number))
        && get(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/staffMembers/$(request.auth.token.phone_number)).data.status == 'active';
    }

    function isDemoStaff() {
      return isDemoStaffByUid() || isDemoStaffByPhone();
    }

    function isSelfCustomer(customerId) {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/customers/$(customerId))
        && get(/databases/$(database)/documents/organizations/org_demo/offices/office_demo/customers/$(customerId)).data.authUid == request.auth.uid;
    }

    function isSelfTransaction(transactionId) {
      return signedIn()
        && resource.data.customerAuthUid == request.auth.uid;
    }

    match /organizations/org_demo {
      allow read: if isDemoStaff();
      allow write: if isDemoStaff();

      match /offices/office_demo {
        // 利用者画面で事業所名・支払い方式などを読むため、ログイン済みユーザーには read のみ許可
        allow read: if isDemoStaff() || signedIn();
        allow write: if isDemoStaff();

        match /staffMembers/{staffId} {
          allow read: if isDemoStaff();
          allow write: if isDemoStaff();
        }

        match /settings/{settingId} {
          allow read: if isDemoStaff() || signedIn();
          allow write: if isDemoStaff();
        }

        match /products/{productId} {
          allow read: if isDemoStaff() || signedIn();
          allow write: if isDemoStaff();
        }

        match /customers/{customerId} {
          allow read: if isDemoStaff() || isSelfCustomer(customerId);

          // 利用者本人は authUid/phone 紐付けなど最低限の更新のみ許可。
          // 残高・請求額・状態・名前などの重要項目は staff / Function 側で更新する。
          allow update: if isDemoStaff()
            || (
              isSelfCustomer(customerId)
              && request.resource.data.diff(resource.data).changedKeys()
                .hasOnly(['authUid', 'phone', 'updatedAt'])
              && request.resource.data.authUid == request.auth.uid
            );

          allow create, delete: if isDemoStaff();
        }

        match /transactions/{transactionId} {
          // 利用者は自分の履歴だけ読む。
          // 購入履歴の作成・残高更新は Cloud Functions createPurchase に寄せる。
          allow read: if isDemoStaff() || isSelfTransaction(transactionId);
          allow write: if isDemoStaff();
        }

        match /{document=**} {
          allow read, write: if isDemoStaff();
        }
      }

      match /{document=**} {
        allow read, write: if isDemoStaff();
      }
    }

    match /organizations/{organizationId} {
      allow read, write: if false;

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /platform/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
